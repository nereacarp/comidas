# ============================================================
# PRODUCTION environment variables — copy to .env and fill in
# ============================================================

# PostgreSQL password (required — no default in production)
DB_PASSWORD=

# JWT signing secret — use a long random string (required — no default in production)
# Generate one: openssl rand -hex 64
JWT_SECRET=

# Public IP or domain of your server (without trailing slash, no http://)
# Used to build the VITE_API_URL for frontend/backoffice at build time
SERVER_IP=

# Comma-separated list of allowed CORS origins for the backend (required in production)
# Example: http://yourdomain.com,http://admin.yourdomain.com
ALLOWED_ORIGINS=

# Gemini API key — only needed for AI recipe import feature (optional)
GEMINI_API_KEY=

# Admin panel secret for the /admin routes (optional — disables admin routes if unset)
ADMIN_SECRET=
