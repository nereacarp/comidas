Variables de entorno: copia este archivo a .env y rellena los valores

# Contraseña de la base de datos (la que quieras)
DB_PASSWORD=

# Clave secreta para cifrar las sesiones de los usuarios
# Genera una aleatoria con openssl rand -hex 64 (o con https://generate-secret.vercel.app/64)
JWT_SECRET=

# Clave de la API de Gemini (solo necesaria si quieres importar recetas con IA)
GEMINI_API_KEY=

# Contraseña para acceder a las rutas de administración (no se usa ahora mismo)
ADMIN_SECRET=
