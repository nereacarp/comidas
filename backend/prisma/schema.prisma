generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String                 @id @default(cuid())
  email              String                 @unique
  passwordHash       String
  name               String
  showCalories       Boolean                @default(true)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  households         HouseholdMember[]
  favorites          UserFavorite[]
  sentInvitations    HouseholdInvitation[]  @relation("InvitationSender")
}

model Household {
  id            String            @id @default(cuid())
  name          String
  accentKey     String            @default("peach")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  members       HouseholdMember[]
  invitations   HouseholdInvitation[]
  recipes       Recipe[]
  tags          Tag[]
  mealPlanItems MealPlanItem[]
  shoppingLists ShoppingList[]
  pantryItems      PantryItem[]
  storageLocations StorageLocation[]
}

enum HouseholdRole {
  OWNER
  EDITOR
  VIEWER
}

model HouseholdMember {
  id          String        @id @default(cuid())
  userId      String
  householdId String
  role        HouseholdRole @default(EDITOR)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model HouseholdInvitation {
  id          String           @id @default(cuid())
  householdId String
  email       String
  role        HouseholdRole    @default(EDITOR)
  status      InvitationStatus @default(PENDING)
  invitedById String
  createdAt   DateTime         @default(now())
  respondedAt DateTime?
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy   User             @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([householdId, email])
  @@index([email, status])
}

enum MealType {
  DESAYUNO
  COMIDA
  CENA
  SNACK
  POSTRE
}

model Recipe {
  id           String             @id @default(cuid())
  title        String
  description  String?
  instructions String?
  prepTime     Int?
  cookTime     Int?
  servings     Int?
  imageUrl     String?
  kcal         Int?
  householdId  String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  household    Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  ingredients  RecipeIngredient[]
  categories   RecipeCategory[]
  tags         RecipeTag[]
  favorites    UserFavorite[]
  mealPlanItems MealPlanItem[]
  shoppingListItems ShoppingListItem[]

  @@index([householdId])
}

model RecipeIngredient {
  id       String @id @default(cuid())
  name     String
  quantity Float?
  unit     String?
  order    Int    @default(0)
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

model RecipeCategory {
  id       String   @id @default(cuid())
  recipeId String
  mealType MealType
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, mealType])
}

model Tag {
  id          String      @id @default(cuid())
  name        String
  color       String?
  householdId String
  createdAt   DateTime    @default(now())
  household   Household   @relation(fields: [householdId], references: [id], onDelete: Cascade)
  recipes     RecipeTag[]

  @@unique([name, householdId])
}

model RecipeTag {
  id       String @id @default(cuid())
  recipeId String
  tagId    String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([recipeId, tagId])
}

model UserFavorite {
  id       String   @id @default(cuid())
  userId   String
  recipeId String
  createdAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
}

model MealPlanItem {
  id             String    @id @default(cuid())
  date           DateTime  @db.Date
  mealType       MealType
  recipeId       String?
  customMealName String?
  householdId    String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  recipe         Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  household      Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@index([householdId, date])
}

model ShoppingList {
  id          String             @id @default(cuid())
  name        String
  startDate   DateTime           @db.Date
  endDate     DateTime           @db.Date
  accentKey   String             @default("peach")
  shareToken  String?            @unique
  householdId String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  household   Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items       ShoppingListItem[]

  @@index([householdId])
}

model StorageLocation {
  id          String       @id @default(cuid())
  name        String
  icon        String       @default("")
  color       String       @default("")
  order        Int          @default(0)
  layoutColumn Int          @default(0)
  layoutSpan   Int          @default(1)
  householdId  String
  createdAt   DateTime     @default(now())
  household   Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  pantryItems PantryItem[]

  @@unique([name, householdId])
}

model PantryItem {
  id          String           @id @default(cuid())
  name        String
  quantity    Float
  unit        String
  locationId  String?
  householdId String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  household   Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  location    StorageLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@index([householdId])
}

model ShoppingListItem {
  id             String       @id @default(cuid())
  name           String
  quantity       Float?
  unit           String?
  checked        Boolean      @default(false)
  isManual       Boolean      @default(false)
  sourceRecipeId String?
  shoppingListId String
  sourceRecipe   Recipe?      @relation(fields: [sourceRecipeId], references: [id], onDelete: SetNull)
  shoppingList   ShoppingList @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)

  @@index([shoppingListId])
}
